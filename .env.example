# ── Per-domain PostgreSQL databases (Railway) ──────────────────────────────────
# Each business gets its own database. Defaults to SQLite for local dev.
DEVOS_DATABASE_URL=postgresql://user:password@host:5432/devos
AGENCY_DATABASE_URL=postgresql://user:password@host:5432/agency
TRADING_DATABASE_URL=postgresql://user:password@host:5432/trading
PORTAL_DATABASE_URL=postgresql://user:password@host:5432/portal

# ── API keys ────────────────────────────────────────────────────────────────────
# DevOS frontend sends X-API-Key: <key> for /devos/* and /trading/* routes
DEVOS_API_KEY=change-me-devos-key
# Agency frontend sends X-API-Key: <key> for /agency/* routes
AGENCY_API_KEY=change-me-agency-key
# Portal admin routes (DevOS uses this to manage portal clients)
PORTAL_ADMIN_KEY=change-me-admin-key
# Client stores send X-Webhook-Secret: <key> for /portal/webhooks/trigger
PORTAL_WEBHOOK_SECRET=change-me-webhook-secret

# ── JWT (portal auth) ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Portal magic link auth ─────────────────────────────────────────────────────
MAGIC_LINK_EXPIRE_MINUTES=15
MAGIC_LINK_SCHEME=devcore://auth/verify
# Public URL of this API — used in the HTTPS magic link page the email links to
PORTAL_API_BASE_URL=https://devcore-backend.railway.app
# Comma-separated emails that auto-create a chief DevOS account on first sign-in
CHIEF_EMAILS=devcore002@gmail.com
CHIEF_BUSINESS_NAME=DevCore HQ
CHIEF_DASHBOARD_URL=https://devos-dashboard-nine.vercel.app

# ── SMTP (portal magic link emails) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=devcore002@gmail.com
SMTP_PASSWORD=your-gmail-app-password-no-spaces

# ── Firebase (portal push notifications) ───────────────────────────────────────
# Set one of these — JSON env var takes priority (preferred for Railway)
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Google OAuth (portal) ──────────────────────────────────────────────────────
# Comma-separated OAuth 2.0 client IDs (web/iOS/Android)
GOOGLE_CLIENT_IDS=

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Cloudinary (content publishing) ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for development only.
ALLOWED_ORIGINS=https://devos-dashboard-nine.vercel.app,https://devcore-agency.vercel.app
